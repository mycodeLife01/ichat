POSTGRES_USER=ichat
POSTGRES_PASSWORD=ichat_password
POSTGRES_DB=ichat
POSTGRES_PORT=5432
API_PORT=8000

DATABASE_URL=postgresql+asyncpg://ichat:ichat_password@postgres:5432/ichat
JWT_SECRET=change-me-local-dev-only
JWT_ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

DEEPSEEK_API_KEY=replace-in-real-deployments
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Server-side defaults for thinking mode; each send/regenerate request may
# override them via thinking_enabled / reasoning_effort in the request body.
DEEPSEEK_THINKING_ENABLED=false
DEEPSEEK_REASONING_EFFORT=high

# Optional override for the assistant's base system prompt. Leave empty to use
# the bundled production prompt in app/prompts/base_system_prompt.md; set a value
# here only to override it without a code change.
DEFAULT_SYSTEM_PROMPT=
# Token budget for the prompt context (system prompt + history). Estimated with
# the provider's count_tokens heuristic; keep well below the model window and
# size it for cost/latency, not the window limit.
CONTEXT_BUDGET_TOKENS=64000
RUN_LEASE_SECONDS=60
# Fallback poll interval. With LISTEN/NOTIFY active the worker is woken up
# immediately when a new run is enqueued; this poll is only a safety net.
WORKER_POLL_INTERVAL_SECONDS=30
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
WORKER_MAX_INFLIGHT_RUNS=8
WORKER_DELTA_BATCH_WINDOW_MS=50
WORKER_DELTA_BATCH_MAX_CHARS=256
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
SSE_FALLBACK_INTERVAL_SECONDS=5.0
AUTO_TITLE_ENABLED=true
SUMMARY_PROVIDER_NAME=deepseek
SUMMARY_MODEL=deepseek-chat
AUTO_TITLE_MAX_CHARS=32
AUTO_TITLE_MAX_OUTPUT_TOKENS=40
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Web search tool (Tavily). Disabled by default; frontend reads
# GET /api/v1/capabilities and only sends web_search_enabled=true when this is
# enabled and a Tavily key is configured.
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
WEB_SEARCH_MAX_TOOL_CALLS=2
WEB_SEARCH_SEARCH_TIMEOUT_SECONDS=12
WEB_SEARCH_EXTRACT_TIMEOUT_SECONDS=8
WEB_SEARCH_TOTAL_TIMEOUT_SECONDS=25
WEB_SEARCH_DEFAULT_MAX_RESULTS=5
WEB_SEARCH_MAX_EXTRACT_RESULTS=3
WEB_SEARCH_MAX_EVIDENCE_CHARS=10000
WEB_SEARCH_MAX_SOURCE_CHARS=1200

# --- Redis / Celery (email delivery + auth rate limiting) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
# Result backend intentionally empty: task outcomes live in email_outbox.
CELERY_RESULT_BACKEND=

# --- Email / verification ---
# Public base URL of the frontend SPA; verification links point here.
FRONTEND_APP_URL=http://localhost:5173
# postmark | console | fake. console prints to logs (local dev); fake collects
# in memory (tests). Postmark fields below are validated ONLY when set to
# postmark.
EMAIL_PROVIDER=console
EMAIL_FROM=iChat <no-reply@mail.feslia.com>
EMAIL_REPLY_TO=
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_BASE_URL=https://api.postmarkapp.com
POSTMARK_TIMEOUT_SECONDS=10

AUTH_EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
AUTH_EMAIL_VERIFICATION_COOLDOWN_SECONDS=60

# Per-IP sliding-window rate limits (limit / window seconds).
AUTH_RATE_REGISTER_IP_LIMIT=5
AUTH_RATE_REGISTER_IP_WINDOW_SECONDS=3600
AUTH_RATE_RESEND_IP_LIMIT=10
AUTH_RATE_RESEND_IP_WINDOW_SECONDS=3600
AUTH_RATE_VERIFY_IP_LIMIT=30
AUTH_RATE_VERIFY_IP_WINDOW_SECONDS=60

EMAIL_OUTBOX_MAX_ATTEMPTS=5
EMAIL_OUTBOX_LEASE_SECONDS=120
EMAIL_OUTBOX_SWEEP_INTERVAL_SECONDS=60
